{
  "rewrites": [
    {
      "source": "/token/:curveId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(twitterbot|discordbot|telegrambot|slackbot|whatsapp|facebookexternalhit|facebot|linkedinbot|pinterest|embedly|applebot|googlebot|bingbot|duckduckbot|vkshare|ia_archiver|w3c_validator).*"
        }
      ],
      "destination": "/api/token-og?page=token&curveId=:curveId"
    },
    {
      "source": "/stats",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(twitterbot|discordbot|telegrambot|slackbot|whatsapp|facebookexternalhit|facebot|linkedinbot|pinterest|embedly|applebot|googlebot|bingbot|duckduckbot|vkshare|ia_archiver|w3c_validator).*"
        }
      ],
      "destination": "/api/token-og?page=stats"
    },
    {
      "source": "/leaderboard",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(twitterbot|discordbot|telegrambot|slackbot|whatsapp|facebookexternalhit|facebot|linkedinbot|pinterest|embedly|applebot|googlebot|bingbot|duckduckbot|vkshare|ia_archiver|w3c_validator).*"
        }
      ],
      "destination": "/api/token-og?page=leaderboard"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "framework": "vite"
}
