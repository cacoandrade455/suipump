# Copy this to .env and fill in your values
# Never commit .env to git

# PostgreSQL connection string from Render
# Get this from: Render Dashboard -> suipump-db -> Connections -> Internal Database URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Sui RPC URL (optional — defaults to Mysten testnet public RPC)
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# V13 package - SEPARATE published lineage (fresh publish 2026-07-17). Existing
# curves keep the V13 type identity forever; read paths include it when set.
SUIPUMP_V13_PACKAGE=0xdf66376f006557b9f81b3455ee786ffd7f2a633488cc3bd31a37ddbdc69bd56b

# V14 package - COMPATIBLE, ADDITIVE upgrade of V13 (GraduationCap). V13 and V14
# COEXIST: V13 stays the type identity of existing curves; V14 defines the NEW
# GraduationCap/GraduationRegistry structs, the GraduationCapIssued /
# GraduationCapRotated event types, and the *_with_cap graduation entrypoints.
SUIPUMP_V14_PACKAGE=0xb6e7cef4d36b3cf0fd84888dd9930ce9abfcc0ed56f01384f1e02b55eeac1b03

# V14 GraduationCap triplet (GRAD-1). With ALL THREE of SUIPUMP_V14_PACKAGE +
# SUIPUMP_GRADUATION_CAP + SUIPUMP_GRADUATION_REGISTRY set, the graduation flow
# calls claim_graduation_funds_with_cap / record_graduation_pool_with_cap on the
# V14 package, GRADUATION_SIGNER_KEY holds ONLY the dedicated graduation wallet
# 0x7334d47632af5386d9b16326ade55be642fc8a569a1672b0cbaaf4d0e7e6180a's key (owner
# of the GraduationCap), and the AdminCap key moves cold. Any of the three unset
# -> pre-V14 AdminCap fallback (TESTNET-ONLY EXPEDIENT, see write_target.js).
SUIPUMP_GRADUATION_CAP=0xe1eeaf7620fe62bc4e0d207821760c69a84758c757c47000790292f1a8d905ee
SUIPUMP_GRADUATION_REGISTRY=0xe1d895aec204ec64e2ad9755080d3dad20d053af6d480c149ae601d375281e8a

# OPTIONAL comma-separated OVERRIDE of the package ID list to index. When unset,
# the worker uses the code default ALL_PACKAGE_IDS in index.js (V4..V12 hardcoded
# plus the env-gated SUIPUMP_V13_PACKAGE / SUIPUMP_V14_PACKAGE ids above). When
# SET, this list WINS over the code default, so it must contain EVERY package id
# (full 66-char ids, never truncated) - including V13 and V14:
PACKAGE_IDS=0x2154486dcf503bd3e8feae4fb913e862f7e2bbf4489769aff63978f55d55b4a8,0x785c0604cb6c60a8547501e307d2b0ca7a586ff912c8abff4edfb88db65b7236,0x21d5b1284d5f1d4d14214654f414ffca20c757ee9f9db7701d3ffaaac62cd768,0xfb8f3f3e4e8d53130ac140906eebea6b6740bfaf0c971aec607fbc723be951f0,0x145a1e79b83cc17680dbfe4f96839cd359c7db380ac15463ecb6dc30f9849b69,0xbb4ee050239f59dfd983501ce101698ba27857f77aff2d437cec568fe0062546,0x719698e5138582d78ee95317271e8bce05769569a4f58c940a7f1b424d90ffe2,0x2deda2cade65cd5afd5ffbe799d48f2491debf08d3aef6fa11aa6e1c8afe1598,0xc03817bce45ff492e5d0f40f9e46f5a075a952b50c5c6146b8fb38138bd699eb,0xf5a3566ba920a3e3614e8b25da0ca3237879b6e22eb12f21ccf2bceb6520b9cd,0xdf66376f006557b9f81b3455ee786ffd7f2a633488cc3bd31a37ddbdc69bd56b,0xb6e7cef4d36b3cf0fd84888dd9930ce9abfcc0ed56f01384f1e02b55eeac1b03

# Poll interval in milliseconds (default 5000)
POLL_MS=5000

# API port (default 3001, Render sets this automatically)
PORT=3001

# Set to 'production' on Render
NODE_ENV=production

# =============================================================================
# CONTENT BOUNTY TRACKER (bounty.js)
# =============================================================================
# Self-contained X-post bounty leaderboard. All vars are OPTIONAL: the poller is
# dormant unless BOTH the provider key AND a contest end (BOUNTY_END_MS > 0) are
# set. The routes (/bounty/*) always mount and degrade to clear "not configured"
# responses. Nothing here touches existing indexer tables or work.

# Provider selection. Only 'twitterapi_io' ships today; the code is written so an
# official X API adapter can be added in x_provider.js without touching bounty.js.
X_PROVIDER=twitterapi_io

# twitterapi.io API key (https://twitterapi.io). Credit-metered, ~$0.15 per 1,000
# tweet-reads. REQUIRED to arm the poller and to accept submissions. NEVER commit
# a real key.
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here
# Optional overrides:
# TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
# BOUNTY_HTTP_TIMEOUT_MS=15000

# Contest window (epoch MILLISECONDS, UTC). BOTH must be set to arm the poller;
# only posts CREATED within [start, end] are ever tracked. Example below is a
# placeholder 2-week window - set the real dates before launch.
BOUNTY_START_MS=0
BOUNTY_END_MS=0
# Keep refreshing (to settle final numbers) for this long after end, then freeze.
# BOUNTY_SETTLE_GRACE_MS=86400000

# Search query used for auto-discovery (advanced_search, queryType=Latest).
# BOUNTY_QUERY=suipump OR @SuiPump_SUMP

# Cadence (milliseconds). Discovery runs at most every DISCOVERY_INTERVAL; the
# poller wakes every POLL_TICK to run discovery-if-due plus the tiered refresh.
# BOUNTY_DISCOVERY_INTERVAL_MS=21600000   # 6h
# BOUNTY_POLL_TICK_MS=3600000             # 1h

# Tiered refresh: fresh posts polled often, plateaued posts rarely. MAX is the
# upper age bound of each tier; INTERVAL is how often to re-poll within it.
# BOUNTY_TIER1_MAX_MS=86400000            # < 1 day
# BOUNTY_TIER1_INTERVAL_MS=21600000       #   every 6h
# BOUNTY_TIER2_MAX_MS=259200000           # 1-3 days
# BOUNTY_TIER2_INTERVAL_MS=43200000       #   every 12h
# BOUNTY_TIER3_MAX_MS=604800000           # 3-7 days
# BOUNTY_TIER3_INTERVAL_MS=86400000       #   every 24h
# BOUNTY_TIER4_INTERVAL_MS=172800000      # > 7 days: every 48h

# Batch size for the multi-id refresh endpoint (twitterapi.io max is undocumented;
# default 20, conservative).
# BOUNTY_BATCH_SIZE=20
# Bounds per sweep/tick so one pass can never run away with the budget.
# BOUNTY_MAX_DISCOVERY_PAGES=3
# BOUNTY_MAX_REFRESH_PER_TICK=200

# Budget governor: monthly ceiling in tweet-reads. As month-to-date usage crosses
# SLOW_PCT the poller widens tiers (x SLOW_FACTOR); at PAUSE_PCT it stops
# discovering new posts (keeps refreshing known ones); at 100% it freezes.
# BOUNTY_MONTHLY_TWEET_BUDGET=5000
# BOUNTY_GOV_SLOW_PCT=0.70
# BOUNTY_GOV_PAUSE_PCT=0.85
# BOUNTY_SLOW_FACTOR=2

# Anti-farming: flag (never auto-punish) a post whose any metric jumps >= MULT x
# between consecutive snapshots, when the earlier value was at least FLOOR.
# BOUNTY_SUSPICIOUS_MULT=5
# BOUNTY_SUSPICIOUS_FLOOR=50
